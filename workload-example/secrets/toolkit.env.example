# ==============================================================================
# Toolkit Deployment Parameters
# ==============================================================================
# These variables are used by the toolkit CLI for deployment operations.
# They are NOT used by docker-compose or containers.
#
# Copy this file to toolkit.env and customize for your deployment.
# ==============================================================================

CSP=gcp
PROJECT_ID=
REGION=asia-southeast1-b
VM_TYPE=c3-standard-4
VM_NAME=cvm-test
BUCKET=
CREATE_IP_NAME=
IP=
ATTACH_DISK=
DISK_SIZE=10
ADDITIONAL_PORTS=
BOOT_DISK_SIZE=
SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub
