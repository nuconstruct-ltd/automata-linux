# ==============================================================================
# Workload Configuration
# ==============================================================================
# This file is read by podman-compose for ${VAR} substitution in
# docker-compose.yml and injected into containers via env_file directive.
# It does NOT affect CVM measurements (PCR 23).
#
# Copy this file and fill in values for your deployment.
# ==============================================================================

# --- Container Images ---
TOOL_NODE_IMAGE=gcr.io/constellation-458212/tool-node:latest
LIGHTHOUSE_IMAGE=docker.io/sigp/lighthouse:latest
NODE_EXPORTER_IMAGE=docker.io/prom/node-exporter:v1.9.1
PROMTAIL_IMAGE=docker.io/grafana/promtail:latest
VMAGENT_IMAGE=docker.io/victoriametrics/vmagent:v1.108.1
CONTROLLER_IMAGE=ghcr.io/nuconstruct-ltd/controller:latest
OPERATOR_IMAGE=ghcr.io/nuconstruct-ltd/operator:latest
CADDY_IMAGE=docker.io/library/caddy:latest

# --- Tool Node ---
NETWORK=mainnet
RELAY_SECRET_KEY=
HISTORY_BLOCKS=512
HISTORY_CHAIN=all

# --- Lighthouse ---
CHECKPOINT_SYNC_URL=https://mainnet.checkpoint.sigp.io
FEE_RECIPIENT=0x00000000000000000000000000000000DeaDBeef

# --- Logging ---
LOKI_HOST=
LOKI_USER=
LOKI_PASSWORD=

# --- Metrics ---
METRICS_HOST=
METRICS_USER=
METRICS_PASSWORD=

# --- Caddy Domains ---
# Set to domain names for automatic HTTPS via Let's Encrypt.
# Leave empty for port-based access with self-signed certs.
CADDY_RPC_DOMAIN=
CADDY_CVM_DOMAIN=
CADDY_CONTROLLER_DOMAIN=

# --- SSH Access ---
SSH_PUBLIC_KEY=
