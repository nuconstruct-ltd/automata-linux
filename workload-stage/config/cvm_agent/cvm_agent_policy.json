{
    "cvm_config": {
        "emulation_mode" :{
            "enable": false,
            "cloud_provider": "azure",
            "tee_type": "snp" ,
            "emulation_data_path": "./emulation_mode_data",
            "enable_emulation_data_update": true
        },

        "firewall": {
            "allowed_ports": [
                { "name": "allow_agent_local", "protocol": "tcp", "port": "7999" },
                { "name": "allow_agent_external", "protocol": "tcp", "port": "8000" },
                { "name": "allow_http", "protocol": "tcp", "port": "80" },
                { "name": "allow_https", "protocol": "tcp", "port": "443" },
                { "name": "allow_controller_ssh", "protocol": "tcp", "port": "2200" },
                { "name": "allow_controller_api", "protocol": "tcp", "port": "8080" },
                { "name": "allow_rpc", "protocol": "tcp", "port": "8545" },
                { "name": "allow_ws", "protocol": "tcp", "port": "8546" },
                { "name": "allow_authrpc", "protocol": "tcp", "port": "8551" },
                { "name": "allow_lighthouse_p2p", "protocol": "tcp", "port": "9000" },
                { "name": "allow_lighthouse_metrics", "protocol": "tcp", "port": "9060" },
                { "name": "allow_node_exporter", "protocol": "tcp", "port": "9100" },
                { "name": "allow_lighthouse_http", "protocol": "tcp", "port": "5052" },
                { "name": "allow_lighthouse_metrics2", "protocol": "tcp", "port": "5054" },
                { "name": "allow_tool_metrics", "protocol": "tcp", "port": "6060" },
                { "name": "allow_p2p", "protocol": "tcp", "port": "30303" },
                { "name": "allow_p2p_udp", "protocol": "udp", "port": "30303" },
                { "name": "allow_lighthouse_p2p_udp", "protocol": "udp", "port": "9000" }
            ],
            "maintenance_mode_host_port": "2222"
        },

        "https_server" :{
            "enable_tls": true,
            "enable_auth": true
        },

        "container_api" : {
            "container_engine": "podman",
            "container_owner": "automata"
        },

        "maintenance_mode" : {
            "allow" : false,
            "signal" : "SIGUSR2"
        },

        "disk_config": {
            "enable": true,
            "disk_mount_point": "/data/data-disk",
            "disk_encryption": {
                "enable": false,
                "encryption_key_security": "standard"
            }
        }
    },

    "workload_config": {
        "services": {
            "allow_remove": false,
            "allow_add_new_service": true,
            "allow_update": ["operator", "controller", "tool-node", "lighthouse", "promtail", "node-exporter", "caddy", "cvm-agent-bridge", "cvm-agent-proxy", "vmagent"],
            "skip_measurement": ["operator", "cvm-agent-bridge", "cvm-agent-proxy", "promtail", "node-exporter", "caddy", "vmagent", "tool-node"]
        },
        "image_signature_verification": {
            "enable":false,
            "auth_info_file_path": "/data/workload/secrets/auth_info.json",
            "signature_verification_policy_path":"/data/workload/config/cvm_agent/sample_image_verify_policy.json"
        }
    }
}
