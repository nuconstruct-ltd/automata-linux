#!/bin/bash

# ============================================================================
# Path Detection - Support both installed and development modes
# ============================================================================
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Running from git clone (development mode)
SCRIPT_DIR="$SCRIPT_PATH/scripts"
TOOLS_DIR="$SCRIPT_PATH/tools"
ARTIFACT_DIR="$SCRIPT_PATH/_artifacts"
DISK_DIR="$SCRIPT_PATH"
mkdir -p "$ARTIFACT_DIR"

# Export variables so child scripts can inherit them
export ARTIFACT_DIR
export SCRIPT_DIR
export TOOLS_DIR

# ============================================================================
# Workload Directory Handling
# ============================================================================
# WORKLOAD_DIR is always ./workload (symlink), exported for child scripts
WORKLOAD_DIR="./workload"
export WORKLOAD_DIR

# Validate and setup workload directory symlink
# Sets ACTUAL_WORKLOAD_DIR to absolute path and creates symlink at ./workload
setup_workload_dir() {
    local dir_arg="$1"
    local cmd_name="$2"

    # Check argument is provided
    if [[ -z "$dir_arg" || "${dir_arg:0:2}" == "--" ]]; then
        echo "❌ WORKLOAD_DIR is required as the first argument."
        echo "❌ Usage: $0 $cmd_name <WORKLOAD_DIR> [options]"
        exit 1
    fi

    # Validate directory exists
    if [[ ! -d "$dir_arg" ]]; then
        echo "❌ Workload directory not found: $dir_arg"
        exit 1
    fi

    # Convert to absolute path
    if [[ "${dir_arg:0:1}" != "/" ]]; then
        ACTUAL_WORKLOAD_DIR="$(cd "$(dirname "$dir_arg")" && pwd)/$(basename "$dir_arg")"
    else
        ACTUAL_WORKLOAD_DIR="$dir_arg"
    fi

    # Check ./workload doesn't already exist
    if [[ -e "$WORKLOAD_DIR" ]]; then
        echo "❌ $WORKLOAD_DIR already exists. Please remove it first."
        exit 1
    fi

    # Create symlink
    ln -s "$ACTUAL_WORKLOAD_DIR" "$WORKLOAD_DIR"

    # Export for child scripts that need the real path (e.g., file transfers)
    export ACTUAL_WORKLOAD_DIR

    # Source env from workload directory if present
    if [[ -f "$ACTUAL_WORKLOAD_DIR/secrets/.env" ]]; then
        set -a
        source "$ACTUAL_WORKLOAD_DIR/secrets/.env"
        set +a
    fi
}

# Cleanup workload symlink
cleanup_workload_dir() {
    if [[ -L "$WORKLOAD_DIR" ]]; then
        rm -f "$WORKLOAD_DIR"
    fi
}

# Generate identity.env in the workload secrets directory.
# Writes VM_NAME, CSP, REGION, PUBLIC_IP for containers to source at runtime.
# Call after VM_NAME, CSP, REGION are resolved.
generate_identity_env() {
    local secrets_dir="$ACTUAL_WORKLOAD_DIR/secrets"
    local identity_file="$secrets_dir/identity.env"
    local ip="${IP:-unknown}"

    # Try to get IP from artifacts if not set
    if [[ "$ip" == "unknown" && -n "${CSP:-}" && -n "${VM_NAME:-}" ]]; then
        local ip_file="$ARTIFACT_DIR/${CSP}_${VM_NAME}_ip"
        [[ -f "$ip_file" ]] && ip=$(<"$ip_file")
    fi

    mkdir -p "$secrets_dir"
    cat > "$identity_file" <<EOF
VM_NAME=${VM_NAME:-unknown}
CSP=${CSP:-unknown}
REGION=${REGION:-unknown}
PUBLIC_IP=${ip}
EOF
    echo "ℹ️  Generated identity.env: VM_NAME=${VM_NAME:-unknown} CSP=${CSP:-unknown} REGION=${REGION:-unknown} IP=${ip}"
}

# ============================================================================
# Dependency Checking and Auto-Installation
# ============================================================================
check_and_install_dependencies() {
    local missing=()
    local deps=("curl" "jq" "unzip" "openssl")

    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            missing+=("$dep")
        fi
    done

    # Check for sha256sum or shasum (macOS uses shasum)
    if ! command -v sha256sum &> /dev/null && ! command -v shasum &> /dev/null; then
        missing+=("coreutils")  # provides sha256sum
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "⚠️  Missing dependencies: ${missing[*]}"
        echo "⌛ Attempting to install..."

        if [[ "$(uname)" == "Darwin" ]]; then
            # macOS - use Homebrew
            if command -v brew &> /dev/null; then
                brew install "${missing[@]}" || {
                    echo "❌ Failed to install dependencies via Homebrew"
                    exit 1
                }
            else
                echo "❌ Homebrew not found. Please install dependencies manually:"
                echo "  brew install ${missing[*]}"
                exit 1
            fi
        elif command -v apt-get &> /dev/null; then
            # Debian/Ubuntu
            sudo apt-get update -qq && sudo apt-get install -y "${missing[@]}" || {
                echo "❌ Failed to install dependencies via apt-get"
                exit 1
            }
        else
            echo "❌ Could not detect package manager. Please install manually:"
            echo "  ${missing[*]}"
            exit 1
        fi

        echo "✅ Dependencies installed successfully"
    fi
}

# Run dependency check early
check_and_install_dependencies

