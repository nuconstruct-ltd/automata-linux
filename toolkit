COMMAND=$1
shift 1  # Shift to process other arguments

if [[ -z "$COMMAND" ]]; then
    usage
fi

case "$COMMAND" in
    deploy-aws)
        # Setup workload directory symlink
        setup_workload_dir "${1:-}" "deploy-aws"
        shift 1
        trap cleanup_workload_dir EXIT

        # Default values (env vars from .env take precedence over hardcoded defaults)
        VM_NAME="${VM_NAME:-cvm-test}"
        BUCKET="${BUCKET:-}"
        REGION="${REGION:-us-east-2}"
        VM_TYPE="${VM_TYPE:-m6a.large}"
        ADDITIONAL_PORTS="${ADDITIONAL_PORTS:-}"
        EIP_AID="${EIP_AID:-}"
        ATTACH_DISK="${ATTACH_DISK:-}"
        DISK_SIZE="${DISK_SIZE:-}"

        while [[ "$#" -gt 0 ]]; do
            case "$1" in
                --additional_ports) ADDITIONAL_PORTS=$2; shift 2 ;;
                --vm_name) VM_NAME=$2; shift 2 ;;
                --region) REGION=$2; shift 2 ;;
                --vm_type) VM_TYPE=$2; shift 2 ;;
                --bucket) BUCKET=$2; shift 2 ;;
                --eip) EIP_AID=$2; shift 2 ;;
                --attach-disk) ATTACH_DISK=$2; shift 2 ;;
                --disk-size) DISK_SIZE=$2; shift 2 ;;
                *) echo "Unknown argument: $1"; usage ;;
            esac
        done

        # === Derive bucket name if not provided ===
        if [[ -z "$BUCKET" ]]; then
            # Check whether bucket exists in _artifacts, use that first, if not generate a new one
            if [[ -f "$ARTIFACT_DIR/aws_${VM_NAME}_bucket" ]]; then
                BUCKET=$(<"$ARTIFACT_DIR/aws_${VM_NAME}_bucket")
                echo "ℹ️  Using existing bucket name from artifacts: $BUCKET"
            else
                # Generate a new bucket name
                SANITIZED_VM_NAME=$(echo "$VM_NAME" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9')
                RANDOM_SUFFIX=$(openssl rand -base64 32 | tr -dc 'a-z0-9' | head -c6)
                BUCKET="${SANITIZED_VM_NAME:-cvm}${RANDOM_SUFFIX}"
                echo "ℹ️  No bucket provided. Using generated bucket name: $BUCKET"
            fi
        fi

        CSP="aws"
        generate_identity_env

        set -euo pipefail
        # Check vm options
        "$SCRIPT_DIR/check_options.sh" "aws" "$VM_TYPE" "$REGION"
        # Change to disk directory for disk operations
        cd "$DISK_DIR"
        # Ensure the disk image exists
        "$SCRIPT_DIR/get_disk_image.sh" "aws"
        # Update the disk image with the workload
        echo "📁 Adding workload from: $ACTUAL_WORKLOAD_DIR"
        "$SCRIPT_DIR/update_disk.sh" "aws_disk.vmdk"
        # Check that CSP CLI dependencies are installed
        "$SCRIPT_DIR/check_csp_deps.sh" "aws"
        # Generate API token for disk
        "$SCRIPT_DIR/generate_api_token.sh" "aws_disk.vmdk" "aws" "$VM_NAME"
        # Deploy the VM
        echo "Deploying aws_disk.vmdk with the following parameters:"
        echo "🔹VM Name: $VM_NAME"
        echo "🔹Region: $REGION"
        echo "🔹VM Type: $VM_TYPE"
        echo "🔹Bucket : $BUCKET"
        echo "🔹EIP Allocation ID: $EIP_AID"
        echo "🔹Additional Ports: $ADDITIONAL_PORTS"
        echo "🔹Attach Disk: ${ATTACH_DISK:-none}"
        echo "🔹Disk Size: ${DISK_SIZE:-default}"
        "$SCRIPT_DIR/make_aws_vm.sh" "$VM_NAME" "$REGION" "$VM_TYPE" "$BUCKET" "$ADDITIONAL_PORTS" "$EIP_AID" "$ATTACH_DISK" "$DISK_SIZE" "$ARTIFACT_DIR"
        "$SCRIPT_DIR/get_golden_measurements.sh" "aws" "$VM_NAME"
        echo "✨ Deployment complete! Your VM Name: $VM_NAME"
        set +e
        cleanup_workload_dir
        ;;

    deploy-gcp)
        # Setup workload directory symlink
        setup_workload_dir "${1:-}" "deploy-gcp"
        shift 1
        trap cleanup_workload_dir EXIT

        # Auto-populate SSH_PUBLIC_KEY from SSH_PUBLIC_KEY_FILE if not set
        if [[ -z "${SSH_PUBLIC_KEY:-}" && -n "${SSH_PUBLIC_KEY_FILE:-}" ]]; then
            EXPANDED_KEY_FILE="${SSH_PUBLIC_KEY_FILE/#\~/$HOME}"
            if [[ -f "$EXPANDED_KEY_FILE" ]]; then
                export SSH_PUBLIC_KEY="$(<"$EXPANDED_KEY_FILE")"
            fi
        fi

        # Default values (env vars from .env take precedence over hardcoded defaults)
        PROJECT_ID="${PROJECT_ID:-}"
        BUCKET="${BUCKET:-}"
        VM_NAME="${VM_NAME:-cvm-test}"
        REGION="${REGION:-asia-southeast1-b}"
        VM_TYPE="${VM_TYPE:-c3-standard-4}"
        ADDITIONAL_PORTS="${ADDITIONAL_PORTS:-}"
        IP="${IP:-}"
        ATTACH_DISK="${ATTACH_DISK:-}"
        DISK_SIZE="${DISK_SIZE:-}"
        BOOT_DISK_SIZE="${BOOT_DISK_SIZE:-}"
        CREATE_IP_NAME="${CREATE_IP_NAME:-}"

        while [[ "$#" -gt 0 ]]; do
            case "$1" in
                --additional_ports) ADDITIONAL_PORTS=$2; shift 2 ;;
                --vm_name) VM_NAME=$2; shift 2 ;;
                --region) REGION=$2; shift 2 ;;
                --project_id) PROJECT_ID=$2; shift 2 ;;
                --vm_type) VM_TYPE=$2; shift 2 ;;
                --bucket) BUCKET=$2; shift 2 ;;
                --ip) IP=$2; shift 2 ;;
                --create-ip) CREATE_IP_NAME=$2; shift 2 ;;
                --attach-disk) ATTACH_DISK=$2; shift 2 ;;
                --disk-size) DISK_SIZE=$2; shift 2 ;;
                --boot-disk-size) BOOT_DISK_SIZE=$2; shift 2 ;;
                *) echo "Unknown argument: $1"; usage ;;
            esac
        done

        # === Check for ATTACH_DISK collision with VM_NAME ===
        if [[ -n "$ATTACH_DISK" && "$ATTACH_DISK" == "$VM_NAME" ]]; then
            ATTACH_DISK="${ATTACH_DISK}-data"
            echo "⚠️  Warning: ATTACH_DISK cannot be the same as VM_NAME. Renamed to: $ATTACH_DISK"
        fi

        # === Derive bucket name if not provided ===
        if [[ -z "$BUCKET" ]]; then
            # Check whether bucket exists in _artifacts, use that first, if not generate a new one
            if [[ -f "$ARTIFACT_DIR/gcp_${VM_NAME}_bucket" ]]; then
                BUCKET=$(<"$ARTIFACT_DIR/gcp_${VM_NAME}_bucket")
                echo "ℹ️  Using existing bucket name from artifacts: $BUCKET"
            else
                # Generate a new bucket name
                SANITIZED_VM_NAME=$(echo "$VM_NAME" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9')
                RANDOM_SUFFIX=$(openssl rand -base64 32 | tr -dc 'a-z0-9' | head -c6)
                BUCKET="${SANITIZED_VM_NAME:-cvm}${RANDOM_SUFFIX}"
                echo "ℹ️  No bucket provided. Using generated bucket name: $BUCKET"
            fi
        fi

        CSP="gcp"
        generate_identity_env

        set -euo pipefail
        # Check vm options
        "$SCRIPT_DIR/check_options.sh" "gcp" "$VM_TYPE" "$REGION"
        # Change to disk directory for disk operations
        cd "$DISK_DIR"
        # Ensure the disk image exists
        "$SCRIPT_DIR/get_disk_image.sh" "gcp"
        # Update the disk image with the workload
        echo "📁 Adding workload from: $ACTUAL_WORKLOAD_DIR"
        # Save and unset DISK_SIZE to avoid conflict with update_disk's --disk-size (boot image format e.g. 8G)
        DATA_DISK_SIZE="$DISK_SIZE"
        DISK_SIZE="${BOOT_DISK_SIZE:+${BOOT_DISK_SIZE}G}"
        export DISK_SIZE
        "$SCRIPT_DIR/update_disk.sh" "gcp_disk.tar.gz"
        DISK_SIZE="$DATA_DISK_SIZE"
        # Check that CSP CLI dependencies are installed
        "$SCRIPT_DIR/check_csp_deps.sh" "gcp"

        # === Derive PROJECT_ID if not provided ===
        if [[ -z "$PROJECT_ID" ]]; then
            PROJECT_ID=$(gcloud config get-value project 2>/dev/null)
            if [[ -z "$PROJECT_ID" ]]; then
                echo "❌ PROJECT_ID not provided and no default found in gcloud config."
                echo "❌ To fix run this command: gcloud init --console-only --no-launch-browser"
                exit 1
            fi
            echo "ℹ️  Using default gcloud project: $PROJECT_ID"
        fi

        # Create/reuse static IP if CREATE_IP_NAME is set
        if [[ -n "$CREATE_IP_NAME" && -z "$IP" ]]; then
            EXISTING_IP=$(gcloud compute addresses describe "$CREATE_IP_NAME" \
                --region="$(echo "$REGION" | sed 's/-[a-z]$//')" \
                --project="$PROJECT_ID" \
                --format='get(address)' 2>/dev/null || true)
            if [[ -n "$EXISTING_IP" ]]; then
                echo "ℹ️  Using existing static IP '$CREATE_IP_NAME': $EXISTING_IP"
                IP="$EXISTING_IP"
            else
                echo "🔧 Creating static IP '$CREATE_IP_NAME'..."
                gcloud compute addresses create "$CREATE_IP_NAME" \
                    --region="$(echo "$REGION" | sed 's/-[a-z]$//')" \
                    --project="$PROJECT_ID"
                IP=$(gcloud compute addresses describe "$CREATE_IP_NAME" \
                    --region="$(echo "$REGION" | sed 's/-[a-z]$//')" \
                    --project="$PROJECT_ID" \
                    --format='get(address)')
                echo "ℹ️  Created static IP: $IP"
            fi
        fi

        # Generate API token for disk
        "$SCRIPT_DIR/generate_api_token.sh" "gcp_disk.tar.gz" "gcp" "$VM_NAME"
        # Deploy the VM
        echo "Deploying gcp_disk.tar.gz with the following parameters:"
        echo "🔹VM Name: $VM_NAME"
        echo "🔹Region: $REGION"
        echo "🔹Project ID: $PROJECT_ID"
        echo "🔹VM Type: $VM_TYPE"
        echo "🔹Bucket : $BUCKET"
        echo "🔹Additional Ports: $ADDITIONAL_PORTS"
        echo "🔹Attach Disk: ${ATTACH_DISK:-none}"
        echo "🔹Disk Size: ${DISK_SIZE:-default}"
        echo "🔹Boot Disk Size: ${BOOT_DISK_SIZE:-default}"
        "$SCRIPT_DIR/make_gcp_vm.sh" "$VM_NAME" "$REGION" "$PROJECT_ID" "$VM_TYPE" "$BUCKET" "$ADDITIONAL_PORTS" "$IP" "$ATTACH_DISK" "$DISK_SIZE" "$ARTIFACT_DIR" "$BOOT_DISK_SIZE"
        "$SCRIPT_DIR/get_golden_measurements.sh" "gcp" "$VM_NAME"
        echo "✨ Deployment complete! Your VM Name: $VM_NAME"
        set +e
        cleanup_workload_dir
        ;;

    deploy-azure)
        # Setup workload directory symlink
        setup_workload_dir "${1:-}" "deploy-azure"
        shift 1
        trap cleanup_workload_dir EXIT

        # Default values (env vars from .env take precedence over hardcoded defaults)
        VM_NAME="${VM_NAME:-cvm-test}"
        VM_TYPE="${VM_TYPE:-Standard_DC2es_v6}"
        REGION="${REGION:-East US}"
        RESOURCE_GROUP="${RESOURCE_GROUP:-}"
        STORAGE_ACC="${STORAGE_ACC:-}"
        GALLERY_NAME="${GALLERY_NAME:-}"
        ADDITIONAL_PORTS="${ADDITIONAL_PORTS:-}"
        ATTACH_DISK="${ATTACH_DISK:-}"
        DISK_SIZE="${DISK_SIZE:-}"

        while [[ "$#" -gt 0 ]]; do
            case "$1" in
                --additional_ports) ADDITIONAL_PORTS=$2; shift 2 ;;
                --vm_name) VM_NAME=$2; shift 2 ;;
                --vm_type) VM_TYPE=$2; shift 2 ;;
                --region) REGION=$2; shift 2 ;;
                --resource_group) RESOURCE_GROUP=$2; shift 2;;
                --storage_account) STORAGE_ACC=$2; shift 2 ;;
                --gallery_name) GALLERY_NAME=$2; shift 2 ;;
                --attach-disk) ATTACH_DISK=$2; shift 2 ;;
                --disk-size) DISK_SIZE=$2; shift 2 ;;
                *) echo "Unknown argument: $1"; usage ;;
            esac
        done

        set -euo pipefail
        # Check that CSP CLI dependencies are installed
        "$SCRIPT_DIR/check_csp_deps.sh" "azure"

        # === Derive from VM_NAME ===
        if [[ -z "$RESOURCE_GROUP" ]]; then
          RESOURCE_GROUP="${VM_NAME}_Rg"
        fi

        RANDOM_SUFFIX=$(openssl rand -base64 32 | tr -dc 'a-z0-9' | head -c4)
        if [[ -z "$STORAGE_ACC" ]]; then
            # Get the name of the first storage account (if any)
            STORAGE_ACC=$(az storage account list --resource-group "$RESOURCE_GROUP" --query "[0].name" --output tsv 2>/dev/null || true)
            if [[ -n "$STORAGE_ACC" ]]; then
                echo "Found storage account: $STORAGE_ACC"
            else
                STORAGE_ACC=$(echo "$VM_NAME" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9' | cut -c1-20)
                STORAGE_ACC="${STORAGE_ACC}${RANDOM_SUFFIX}"
                while [[ ${#STORAGE_ACC} -lt 3 ]]; do
                    STORAGE_ACC="${STORAGE_ACC}0"
                done
            fi
        fi
        if [[ -z "$GALLERY_NAME" ]]; then
            # Get the name of the first Shared Image Gallery (if any)
            GALLERY_NAME=$(az sig list --resource-group "$RESOURCE_GROUP" --query "[0].name" --output tsv 2>/dev/null || true)
            if [[ -n "$GALLERY_NAME" ]]; then
                echo "Found shared image gallery: $GALLERY_NAME"
            else
                GALLERY_NAME=$(echo "$VM_NAME" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9_.' | sed 's/^[_.]*//;s/[_.]*$//' | cut -c1-80)
                GALLERY_NAME="${GALLERY_NAME}${RANDOM_SUFFIX}"
            fi
        fi
        # In case the resource group exists, ensure the region matches
        LOCATION=$(az group show --name "$RESOURCE_GROUP" --query "location" --output tsv 2>/dev/null || true)
        if [[ -n "$LOCATION" ]]; then
            FRIENDLY_LOCATION=$(az account list-locations --query "[?name=='$LOCATION'].displayName" --output tsv)
            if [[ "$FRIENDLY_LOCATION" != "$REGION" ]]; then
                echo "Resource group is in $FRIENDLY_LOCATION. Updating REGION to match."
                REGION="$FRIENDLY_LOCATION"
            fi
        fi

        CSP="azure"
        generate_identity_env

        # Check vm options
        "$SCRIPT_DIR/check_options.sh" "azure" "$VM_TYPE" "$REGION"
        # Change to disk directory for disk operations
        cd "$DISK_DIR"
        # Ensure the disk image exists
        "$SCRIPT_DIR/get_disk_image.sh" "azure"
        # Update the disk image with the workload
        echo "📁 Adding workload from: $ACTUAL_WORKLOAD_DIR"
        "$SCRIPT_DIR/update_disk.sh" "azure_disk.vhd"
        # Generate API token for disk
        "$SCRIPT_DIR/generate_api_token.sh" "azure_disk.vhd" "azure" "$VM_NAME"
        echo "Deploying azure_disk.vhd with the following parameters:"
        echo "🔹VM Name: $VM_NAME"
        echo "🔹Resource Group: $RESOURCE_GROUP"
        echo "🔹Region: $REGION"
        echo "🔹VM Type: $VM_TYPE"
        echo "🔹Additional Ports: $ADDITIONAL_PORTS"
        echo "🔹Storage Account: $STORAGE_ACC"
        echo "🔹Shared Image Gallery: $GALLERY_NAME"
        echo "🔹Attach Disk: ${ATTACH_DISK:-none}"
        echo "🔹Disk Size: ${DISK_SIZE:-default}"

        "$SCRIPT_DIR/make_azure_vm.sh" "$VM_NAME" "$RESOURCE_GROUP" "$VM_TYPE" "$ADDITIONAL_PORTS"  \
                        "$STORAGE_ACC" "$GALLERY_NAME" "$REGION" "$ATTACH_DISK" "$DISK_SIZE" "$ARTIFACT_DIR"
        "$SCRIPT_DIR/get_golden_measurements.sh" "azure" "$VM_NAME"
        echo "✨ Deployment complete! Your VM Name: $VM_NAME"
        set +e
        cleanup_workload_dir
        ;;

    update-workload)
        # Setup workload directory symlink
        setup_workload_dir "${1:-}" "update-workload"
        shift 1
        trap cleanup_workload_dir EXIT

        CSP="${1:-}"; shift 1 || true
        VM_NAME="${1:-}"; shift 1 || true
        if [[ -z "$CSP" || -z "$VM_NAME" ]]; then
            echo "❌ Please provide the CSP (aws, gcp or azure) and VM name."
            echo "❌ Usage: $0 update-workload <WORKLOAD_DIR> <CSP> <VM_NAME>"
            exit 1
        fi
        generate_identity_env
        set -euo pipefail
        "$SCRIPT_DIR/update_remote_workload.sh" "$CSP" "$VM_NAME"
        echo "Updating golden measurements..."
        "$SCRIPT_DIR/get_golden_measurements.sh" "$CSP" "$VM_NAME"
        set +e
        cleanup_workload_dir
        ;;

    get-disk)
        CSP=$1; shift 1
        if [[ -z "$CSP" ]]; then
            echo "❌ Please provide the CSP (aws, gcp or azure)."
            echo "❌ Usage: $0 get-disk <CSP>"
            exit 1
        fi
        cd "$DISK_DIR"
        "$SCRIPT_DIR/get_disk_image.sh" "$CSP"
        ;;

    download-build-provenance)
        echo "📦 Downloading SLSA build provenance..."
        cd "$DISK_DIR"
        "$SCRIPT_DIR/get_build_provenance.sh"
        ;;

    verify-build-provenance)
        DISK_FILE=$1; shift 1
        BUNDLE_FILE="${1:-}"
        if [[ -z "$DISK_FILE" ]]; then
            echo "❌ Please provide the disk file to verify"
            echo "❌ Usage: $0 verify-build-provenance <DISK_FILE> [BUNDLE_FILE]"
            exit 1
        fi
        if [[ -n "$BUNDLE_FILE" ]]; then
            "$SCRIPT_DIR/verify_build_provenance.sh" "$DISK_FILE" "$BUNDLE_FILE"
        else
            "$SCRIPT_DIR/verify_build_provenance.sh" "$DISK_FILE"
        fi
        ;;

    update-disk)
        DISK_FILE=""
        DISK_SIZE="${DISK_SIZE:-}"
        HAS_WORKLOAD_ARG=false

        # Check if first arg is a directory (workload) or file (disk)
        if [[ -n "${1:-}" && -d "$1" ]]; then
            setup_workload_dir "$1" "update-disk"
            shift 1
            trap cleanup_workload_dir EXIT
            HAS_WORKLOAD_ARG=true
        fi

        # Parse remaining args
        while [[ "$#" -gt 0 ]]; do
            case "$1" in
                --disk-size) DISK_SIZE=$2; shift 2 ;;
                *)
                    if [[ -z "$DISK_FILE" ]]; then
                        DISK_FILE="$1"; shift 1
                    else
                        echo "Unknown argument: $1"; usage
                    fi
                    ;;
            esac
        done

        if [[ -z "$DISK_FILE" ]]; then
            echo "❌ Please provide the disk file path."
            echo "❌ Usage: $0 update-disk [WORKLOAD_DIR] <DISK_PATH> [--disk-size NGB]"
            exit 1
        fi

        export DISK_SIZE
        echo "📀 Updating disk: $DISK_FILE"
        if [[ "$HAS_WORKLOAD_ARG" == true ]]; then
            echo "📁 Workload source: $ACTUAL_WORKLOAD_DIR"
        else
            echo "📁 Workload source: ./workload (default)"
            # Set WORKLOAD_DIR for update_disk.sh when using default
            export WORKLOAD_DIR="./workload"
        fi
        if [[ -n "$DISK_SIZE" ]]; then
            echo "📏 Target disk size: $DISK_SIZE"
        fi
        cd "$DISK_DIR"
        "$SCRIPT_DIR/update_disk.sh" "$DISK_FILE"
        [[ "$HAS_WORKLOAD_ARG" == true ]] && cleanup_workload_dir
        ;;

    resize-disk)
        DISK_FILE=""
        DISK_SIZE=""

        # Parse args: accept both positional and --disk-size flag
        while [[ "$#" -gt 0 ]]; do
            case "$1" in
                --disk-size) DISK_SIZE="$2"; shift 2 ;;
                *)
                    if [[ -z "$DISK_FILE" ]]; then
                        DISK_FILE="$1"; shift 1
                    elif [[ -z "$DISK_SIZE" ]]; then
                        DISK_SIZE="$1"; shift 1
                    else
                        echo "Unknown argument: $1"; usage
                    fi
                    ;;
            esac
        done

        if [[ -z "$DISK_FILE" || -z "$DISK_SIZE" ]]; then
            echo "❌ Please provide the disk file path and target size."
            echo "❌ Usage: $0 resize-disk <DISK_PATH> <SIZE>"
            echo "❌    or: $0 resize-disk <DISK_PATH> --disk-size <SIZE>"
            exit 1
        fi

        echo "📀 Resizing disk: $DISK_FILE"
        echo "📏 Target size: $DISK_SIZE"
        cd "$DISK_DIR"
        # Unset WORKLOAD_DIR to trigger resize-only mode
        WORKLOAD_DIR="" DISK_SIZE="$DISK_SIZE" "$SCRIPT_DIR/update_disk.sh" "$DISK_FILE"
        ;;

    get-logs)
        CSP=$1; shift 1
        VM_NAME=$1; shift 1
        if [[ -z "$CSP" || -z "$VM_NAME" ]]; then
            echo "❌ Please provide the CSP (aws, gcp or azure) and VM name."
            echo "❌ Usage: $0 get-logs <CSP> <VM_NAME>"
            exit 1
        fi
        set -euo pipefail
        "$SCRIPT_DIR/get_cvm_logs.sh" "$CSP" "$VM_NAME" "$@"
        set +e
        ;;

    cleanup)
        CSP=$1; shift 1
        VM_NAME=$1; shift 1
        if [[ -z "$CSP" || -z "$VM_NAME" ]]; then
            echo "❌ Please provide the CSP (aws, gcp or azure) and VM name."
            echo "❌ Usage: $0 cleanup <CSP> <VM_NAME>"
            exit 1
        fi
        case "$CSP" in
            aws)
                "$SCRIPT_DIR/cleanup_aws_vm.sh" "$VM_NAME" "$ARTIFACT_DIR"
                ;;
            gcp)
                "$SCRIPT_DIR/cleanup_gcp_vm.sh" "$VM_NAME" "$ARTIFACT_DIR"
                ;;
            azure)
                "$SCRIPT_DIR/cleanup_azure_vm.sh" "$VM_NAME" "$ARTIFACT_DIR"
                ;;
        esac
        ;;

    cleanup-local)
        echo "🧹 Cleaning up local artifacts..."

        # Clean disk images
        DISK_FILES=("aws_disk.vmdk" "gcp_disk.tar.gz" "azure_disk.vhd")
        for disk in "${DISK_FILES[@]}"; do
            if [[ -f "$DISK_DIR/$disk" ]]; then
                rm -f "$DISK_DIR/$disk"
                echo "  Removed: $DISK_DIR/$disk"
            fi
        done

        # Clean build provenance bundles
        for disk in "${DISK_FILES[@]}"; do
            if [[ -f "$DISK_DIR/${disk}.bundle" ]]; then
                rm -f "$DISK_DIR/${disk}.bundle"
                echo "  Removed: $DISK_DIR/${disk}.bundle"
            fi
        done

        # Clean artifacts directory
        if [[ -d "$ARTIFACT_DIR" ]]; then
            rm -rf "$ARTIFACT_DIR"/*
            echo "  Cleaned: $ARTIFACT_DIR"
        fi

        echo "✅ Local cleanup complete!"
        ;;

    sign-livepatch)
        LIVEPATCH_FILE=$1; shift 1
        if [[ -z "$LIVEPATCH_FILE" ]]; then
            echo "❌ Please provide the livepatch file (e.g., /path/to/livepatch.ko)"
            echo "❌ Usage: $0 sign-livepatch <LIVEPATCH_FILE>"
            exit 1
        fi
        set -euo pipefail
        "$SCRIPT_DIR/sign_livepatch.sh" "$LIVEPATCH_FILE"
        echo "Livepatch signed successfully: $LIVEPATCH_FILE"
        set +e
        ;;

    livepatch)
        CSP=$1; shift 1
        VM_NAME=$1; shift 1
        LIVEPATCH_PATH=$1; shift 1
        if [[ -z "$CSP" || -z "$VM_NAME" || -z "$LIVEPATCH_PATH" ]]; then
            echo "❌ Please provide the CSP (aws, gcp or azure), VM name, and path to the livepatch file."
            echo "❌ Usage: $0 livepatch <CSP> <VM_NAME> <PATH_TO_LIVEPATCH>"
            exit 1
        fi
        set -euo pipefail
        "$SCRIPT_DIR/livepatch.sh" "$CSP" "$VM_NAME" "$LIVEPATCH_PATH"
        set +e
        ;;

    generate-livepatch-keys)
        # Generate livepatch keys
        "$SCRIPT_DIR/generate_livepatch_keys.sh"
        ;;

    sign-image)
        SOURCE_IMAGE="$1"
        TARGET_IMAGE="$2"
        COSIGN_PRI="$3"
        COSIGN_PUB="$4"

        if [[ -z "$SOURCE_IMAGE" || -z "$TARGET_IMAGE" || -z "$COSIGN_PRI" || -z "$COSIGN_PUB" ]]; then
            echo "❌ Usage: $0 sign-image <source-image> <target-image> <cosign.key> <cosign.pub>"
            echo "Example: $0 sign-image alpine:latest docker.io/user/alpine:signed cosign.key cosign.pub"
            exit 1
        fi
        "$SCRIPT_DIR/sign-and-verify.sh" "$SOURCE_IMAGE" "$TARGET_IMAGE" "$COSIGN_PRI" "$COSIGN_PUB"
        ;;

    *)
        echo "Unknown command: $COMMAND"
        usage
        ;;
esac

exit 0
